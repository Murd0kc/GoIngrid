{
  "id": "A1-M1-T01",
  "level": "A1",
  "module_code": "A1-M1",
  "topic": "El alfabeto y los sonidos principales",
  "title": "Letters, names and sounds",
  "estimated_seconds": 3600,
  "communication_goal": "Deletrear nombres y palabras básicas y pedir aclaración.",
  "cefr_objectives": [
    "Can recognize and name familiar letters.",
    "Can spell a name or simple word.",
    "Can ask for repetition or clarification."
  ],
  "explanation_es": "El alfabeto inglés tiene 26 letras. El nombre de una letra y el sonido dentro de una palabra pueden ser diferentes. En este tema primero aprendemos a reconocer, decir y deletrear letras.",
  "key_language": [
    "How do you spell your name?",
    "It's A-N-A.",
    "Could you repeat that, please?",
    "Is that B or V?"
  ],
  "spanish_speaker_notes": [
    "B /biː/ y V /viː/ deben distinguirse.",
    "W se pronuncia /ˈdʌbəljuː/.",
    "H se llama /eɪtʃ/.",
    "No añadas una vocal después de una consonante al deletrear."
  ],
  "pronunciation_targets": [
    {"text":"A","ipa":"/eɪ/","error":"pronunciarla como la a española"},
    {"text":"E","ipa":"/iː/","error":"confundirla con I"},
    {"text":"B","ipa":"/biː/","error":"confundirla con V"},
    {"text":"V","ipa":"/viː/","error":"pronunciarla como B"},
    {"text":"W","ipa":"/ˈdʌbəljuː/","error":"reducirla a una sílaba"}
  ],
  "vocabulary": [
    {"term":"letter","meaning_es":"letra"},
    {"term":"alphabet","meaning_es":"alfabeto"},
    {"term":"spell","meaning_es":"deletrear"},
    {"term":"first letter","meaning_es":"primera letra"},
    {"term":"last letter","meaning_es":"última letra"},
    {"term":"repeat","meaning_es":"repetir"},
    {"term":"email address","meaning_es":"dirección de correo"}
  ],
  "lessons": [
    {
      "id":"A1-M1-T01-L01",
      "title":"The alphabet",
      "objective":"Reconocer y producir nombres de letras.",
      "estimated_seconds":900,
      "activities":[
        {"id":"A1-M1-T01-L01-E01","type":"multiple_choice","skill":"listening","instruction":"Escucha /biː/ y elige la letra.","prompt":"/biː/","options":["B","V","D"],"correct_answer":"B","feedback_correct":"B se llama /biː/.","feedback_incorrect":"V es /viː/; B es /biː/.","difficulty":1,"estimated_seconds":35},
        {"id":"A1-M1-T01-L01-E02","type":"matching","skill":"vocabulary","instruction":"Elige la palabra para letra.","prompt":"letra","options":["letter","later","little"],"correct_answer":"letter","feedback_correct":"Letter significa letra.","feedback_incorrect":"La palabra correcta es letter.","difficulty":1,"estimated_seconds":30},
        {"id":"A1-M1-T01-L01-E03","type":"ordering","skill":"grammar","instruction":"Ordena la pregunta.","prompt":"spell / your / name / How / do / you?","correct_answer":"How do you spell your name?","feedback_correct":"La pregunta está bien formada.","feedback_incorrect":"Empieza con How do you.","difficulty":1,"estimated_seconds":45},
        {"id":"A1-M1-T01-L01-E04","type":"multiple_choice","skill":"grammar","instruction":"Completa la frase.","prompt":"How do you ___ your name?","options":["spell","spells","spelling"],"correct_answer":"spell","feedback_correct":"Después de do you usamos el verbo base.","feedback_incorrect":"Usa el verbo base después de do you.","difficulty":1,"estimated_seconds":35},
        {"id":"A1-M1-T01-L01-E05","type":"dictation","skill":"listening","instruction":"Escribe las letras.","prompt":"A-N-A","correct_answer":"ANA","feedback_correct":"Correcto.","feedback_incorrect":"Escribe A, N y A.","difficulty":1,"estimated_seconds":50},
        {"id":"A1-M1-T01-L01-E06","type":"pronunciation","skill":"pronunciation","instruction":"Graba A, E e I.","prompt":"A, E, I","evaluation_criteria":["distingue /eɪ/ de /iː/"],"feedback_correct":"Compara A /eɪ/ y E /iː/.","feedback_incorrect":"Repite una letra cada vez con el modelo.","difficulty":1,"estimated_seconds":60},
        {"id":"A1-M1-T01-L01-E07","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"My name is Leo. L-E-O.","question":"How does Leo spell his name?","correct_answer":"L-E-O","feedback_correct":"Encontraste las letras.","feedback_incorrect":"Mira lo que aparece después de spell.","difficulty":1,"estimated_seconds":35},
        {"id":"A1-M1-T01-L01-E08","type":"writing","skill":"writing","instruction":"Escribe tu nombre y deletrealo.","prompt":"Write your first name and spell it.","response_type":"open","evaluation_criteria":["nombre","letras separadas"],"feedback_correct":"Tu respuesta tiene nombre y deletreo.","feedback_incorrect":"Escribe: Ana. A-N-A.","difficulty":1,"estimated_seconds":60},
        {"id":"A1-M1-T01-L01-E09","type":"roleplay","skill":"interaction","instruction":"Responde al administrador.","prompt":"How do you spell your first name?","role":"class administrator","response_type":"open_speaking","success_criteria":["spells name clearly"],"feedback_correct":"La persona puede registrar tu nombre.","feedback_incorrect":"Usa: It's... y di cada letra.","difficulty":1,"estimated_seconds":75},
        {"id":"A1-M1-T01-L01-E10","type":"review","skill":"review","instruction":"Traduce la pregunta.","prompt":"¿Cómo deletreas tu nombre?","correct_answer":"How do you spell your name?","feedback_correct":"Frase recuperada.","feedback_incorrect":"Recuerda How do you spell...?.","difficulty":1,"estimated_seconds":40}
      ]
    },
