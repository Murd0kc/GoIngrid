        {"id":"A1-M1-T01-L02-E02","type":"multiple_choice","skill":"pronunciation","instruction":"Elige el nombre de W.","prompt":"W","options":["double you","wee","dabel"],"correct_answer":"double you","feedback_correct":"W tiene varias sílabas.","feedback_incorrect":"El nombre completo es double you.","difficulty":1,"estimated_seconds":35},
        {"id":"A1-M1-T01-L02-E03","type":"multiple_choice","skill":"pronunciation","instruction":"Elige el nombre de H.","prompt":"H","options":["aitch","ha","eich"],"correct_answer":"aitch","feedback_correct":"H se llama aitch.","feedback_incorrect":"Aitch termina con /tʃ/.","difficulty":1,"estimated_seconds":35},
        {"id":"A1-M1-T01-L02-E04","type":"ordering","skill":"listening","instruction":"Ordena las letras.","prompt":"C - A - T","correct_answer":"C-A-T","feedback_correct":"Orden correcto.","feedback_incorrect":"Escucha cada letra.","difficulty":1,"estimated_seconds":45},
        {"id":"A1-M1-T01-L02-E05","type":"error_correction","skill":"pronunciation","instruction":"Corrige la afirmación.","prompt":"B and V have the same English letter name.","correct_answer":"B and V have different English letter names.","feedback_correct":"B es /biː/ y V es /viː/.","feedback_incorrect":"Cambia same por different.","difficulty":2,"estimated_seconds":45},
        {"id":"A1-M1-T01-L02-E06","type":"pronunciation","skill":"pronunciation","instruction":"Graba B, V, W y H.","prompt":"B, V, W, H","evaluation_criteria":["contraste B/V","W con varias sílabas","H con /tʃ/"],"feedback_correct":"La claridad es más importante que la velocidad.","feedback_incorrect":"Practica cada letra por separado.","difficulty":2,"estimated_seconds":75},
        {"id":"A1-M1-T01-L02-E07","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"Last name: Brown","question":"What is the first letter?","correct_answer":"B","feedback_correct":"Brown comienza con B.","feedback_incorrect":"Mira el inicio de Brown.","difficulty":1,"estimated_seconds":35},
        {"id":"A1-M1-T01-L02-E08","type":"writing","skill":"writing","instruction":"Crea un correo ficticio y deletrea su parte principal.","prompt":"Create a simple fictional email.","response_type":"open","evaluation_criteria":["usa @","usa un punto","deletrea el nombre"],"feedback_correct":"El formato es comprensible.","feedback_incorrect":"Incluye @ y un dominio.","difficulty":2,"estimated_seconds":70},
        {"id":"A1-M1-T01-L02-E09","type":"roleplay","skill":"interaction","instruction":"Pide aclaración durante una llamada.","prompt":"Ask: Is that B or V?","role":"phone support agent","response_type":"open_speaking","success_criteria":["asks clarification clearly"],"feedback_correct":"La pregunta evita una confusión real.","feedback_incorrect":"Usa exactamente: Is that B or V?","difficulty":2,"estimated_seconds":70},
        {"id":"A1-M1-T01-L02-E10","type":"review","skill":"review","instruction":"Elige la afirmación correcta.","prompt":"Which statement is correct?","options":["B and V are identical.","B is /biː/ and V is /viː/.","W is one syllable."],"correct_answer":"B is /biː/ and V is /viː/.","feedback_correct":"Correcto.","feedback_incorrect":"Compara el primer sonido de B y V.","difficulty":2,"estimated_seconds":40}
