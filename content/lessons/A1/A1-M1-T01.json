        {"id":"A1-M1-T01-L04-E02","type":"listening_detail","skill":"listening","instruction":"Responde.","prompt":"My email is luis.green@example.com. Is the first letter L? Yes.","question":"What is the first letter?","correct_answer":"L","feedback_correct":"La primera letra es L.","feedback_incorrect":"La conversación confirma L.","difficulty":2,"estimated_seconds":40},
        {"id":"A1-M1-T01-L04-E03","type":"multiple_choice","skill":"grammar","instruction":"Elige la petición correcta.","prompt":"___ repeat that, please?","options":["Could you","You could","Could repeat you"],"correct_answer":"Could you","feedback_correct":"Es una petición cortés.","feedback_incorrect":"La estructura es Could you repeat...?.","difficulty":2,"estimated_seconds":35},
        {"id":"A1-M1-T01-L04-E04","type":"error_correction","skill":"pronunciation","instruction":"Corrige el problema.","prompt":"The learner says B and V with the same /b/ sound.","correct_answer":"Use /b/ for B and /v/ for V.","feedback_correct":"El contraste hace comprensible la letra.","feedback_incorrect":"V necesita el sonido /v/.","difficulty":2,"estimated_seconds":50},
