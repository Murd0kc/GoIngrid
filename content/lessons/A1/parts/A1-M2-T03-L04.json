{
  "id":"A1-M2-T03-L04",
  "level":"A1",
  "module_code":"A1-M2",
  "topic":"Auxiliares do y does",
  "title":"Integrated interview",
  "objective":"Usar do y does en una entrevista cotidiana.",
  "activities":[
    {"id":"A1-M2-T03-L04-E01","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"Does Ana work? Yes, she does. Does she work at home? No, she doesn't.","options":["trabaja, pero no en casa","no trabaja","trabaja en casa"],"correct_answer":"trabaja, pero no en casa","feedback_correct":"Entendiste las dos respuestas.","feedback_incorrect":"Escucha Yes y luego No.","difficulty":2,"estimated_seconds":55},
    {"id":"A1-M2-T03-L04-E02","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"___ your friends study English?","options":["Do","Does","Is"],"correct_answer":"Do","feedback_correct":"Friends es plural y usa do.","feedback_incorrect":"Un sujeto plural usa do.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T03-L04-E03","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"Does they live here?","correct_answer":"Do they live here?","feedback_correct":"They usa do.","feedback_incorrect":"Cambia Does por Do.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M2-T03-L04-E04","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"does / What / she / eat?","correct_answer":"What does she eat?","feedback_correct":"Pregunta correcta.","feedback_incorrect":"What + does + she + base verb.","difficulty":1,"estimated_seconds":45},
    {"id":"A1-M2-T03-L04-E05","type":"pronunciation","skill":"pronunciation","instruction":"Lee el diálogo.","prompt":"Do you work? Yes, I do. Does she work? No, she doesn't.","evaluation_criteria":["do/does contrast","short answer stress","negative clear"],"feedback_correct":"El diálogo es comprensible.","feedback_incorrect":"Practica las respuestas por pares.","difficulty":2,"estimated_seconds":90},
    {"id":"A1-M2-T03-L04-E06","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"Do the students live near school? Yes, they do. Does Marco live near school? No, he doesn't.","question":"Who does not live near school?","correct_answer":"Marco.","feedback_correct":"La segunda respuesta lo indica.","feedback_incorrect":"Busca No, he doesn't.","difficulty":2,"estimated_seconds":50},
    {"id":"A1-M2-T03-L04-E07","type":"writing","skill":"writing","instruction":"Escribe una entrevista.","prompt":"Write six questions and answers about work, study, food and routines.","response_type":"open","evaluation_criteria":["do/does","short answers","base verbs"],"feedback_correct":"La entrevista está bien formada.","feedback_incorrect":"Comprueba do/does según el sujeto.","difficulty":2,"estimated_seconds":120},
    {"id":"A1-M2-T03-L04-E08","type":"ai_roleplay","skill":"interaction","instruction":"Entrevista a la IA.","prompt":"Ask about the AI's routine, answer follow-up questions and correct one misunderstanding.","role":"native-speaking coworker","response_type":"open_speaking","success_criteria":["do questions","does question","short answers","repair"],"feedback_correct":"La IA evalúa precisión y reparación.","feedback_incorrect":"Reformula con Do o Does según el sujeto.","difficulty":2,"estimated_seconds":160},
    {"id":"A1-M2-T03-L04-E09","type":"transfer","skill":"speaking","instruction":"Haz una encuesta.","prompt":"Ask three people or imagine three people and report their answers.","response_type":"open_speaking","evaluation_criteria":["three questions","do/does","clear report"],"feedback_correct":"Aplicaste los auxiliares fuera de frases memorizadas.","feedback_incorrect":"Usa Does al hablar de una persona.","difficulty":2,"estimated_seconds":110},
    {"id":"A1-M2-T03-L04-E10","type":"mastery_assessment","skill":"assessment","instruction":"Completa la evaluación.","prompt":"Ask five questions, answer five short questions and report one person's habits.","response_type":"open_speaking_and_writing","evaluation_criteria":["do/does accuracy","base verbs","short answers","transfer"],"feedback_correct":"Tema dominado.","feedback_incorrect":"Repasa el auxiliar asociado al sujeto que causó dificultad.","difficulty":2,"estimated_seconds":180}
  ]
}
