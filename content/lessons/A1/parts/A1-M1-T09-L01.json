{
  "id":"A1-M1-T09-L01",
  "level":"A1",
  "module_code":"A1-M1",
  "topic":"There is y there are",
  "title":"There is",
  "objective":"Decir que existe una cosa en un lugar.",
  "activities":[
    {"id":"A1-M1-T09-L01-E01","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"___ a book on the table.","options":["There is","There are","It is"],"correct_answer":"There is","feedback_correct":"There is se usa con singular.","feedback_incorrect":"Book es singular.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T09-L01-E02","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"There is ___ apple in the bag.","options":["a","an","are"],"correct_answer":"an","feedback_correct":"Apple empieza con sonido vocálico.","feedback_incorrect":"Usa an antes de apple.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T09-L01-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"is / There / a / chair","correct_answer":"There is a chair.","feedback_correct":"Frase correcta.","feedback_incorrect":"Empieza con There is.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T09-L01-E04","type":"matching","skill":"vocabulary","instruction":"Relaciona.","prompt":"There is","options":["hay una cosa","hay varias cosas","ellos son"],"correct_answer":"hay una cosa","feedback_correct":"There is introduce singular.","feedback_incorrect":"There are es plural.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T09-L01-E05","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"There are a table.","correct_answer":"There is a table.","feedback_correct":"Table es singular.","feedback_incorrect":"Cambia are por is.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M1-T09-L01-E06","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"There is a window.","options":["una ventana","dos ventanas","una puerta"],"correct_answer":"una ventana","feedback_correct":"Escuchaste there is y window.","feedback_incorrect":"Window significa ventana.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T09-L01-E07","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"There is a book. There is an apple.","evaluation_criteria":["there is clear","article linking","/ð/ intelligible"],"feedback_correct":"La existencia se entiende claramente.","feedback_incorrect":"Une there is con el artículo sin omitir palabras.","difficulty":2,"estimated_seconds":65},
    {"id":"A1-M1-T09-L01-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"There is a lamp in the room.","question":"What is in the room?","correct_answer":"A lamp.","feedback_correct":"La lámpara aparece después de there is.","feedback_incorrect":"Busca el sustantivo.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M1-T09-L01-E09","type":"writing","skill":"writing","instruction":"Describe una habitación.","prompt":"Write four sentences with There is and singular objects.","response_type":"open","evaluation_criteria":["four there is sentences","articles","clear locations"],"feedback_correct":"Describiste la habitación con singular.","feedback_incorrect":"Usa There is + article + noun.","difficulty":1,"estimated_seconds":75},
    {"id":"A1-M1-T09-L01-E10","type":"roleplay","skill":"interaction","instruction":"Describe un lugar.","prompt":"Tell the AI what is in a room using four There is sentences.","role":"visitor","response_type":"open_speaking","success_criteria":["four singular items","there is"],"feedback_correct":"La descripción es clara.","feedback_incorrect":"Cada cosa singular necesita There is.","difficulty":2,"estimated_seconds":100}
  ]
}
