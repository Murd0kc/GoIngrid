    {"id":"A1-M2-T02-L02-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"plays / She / tennis","correct_answer":"She plays tennis.","feedback_correct":"La frase es correcta.","feedback_incorrect":"Empieza con She y usa plays.","difficulty":1,"estimated_seconds":40},
