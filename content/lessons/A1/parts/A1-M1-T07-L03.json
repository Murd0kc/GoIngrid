  "module_code":"A1-M1",
  "topic":"Adjetivos posesivos",
  "title":"Whose is it?",
  "objective":"Preguntar y responder sobre pertenencia.",
  "activities":[
    {"id":"A1-M1-T07-L03-E01","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"___ book is this?","options":["Whose","Who","What"],"correct_answer":"Whose","feedback_correct":"Whose pregunta por pertenencia.","feedback_incorrect":"Usa Whose para preguntar de quién es.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T07-L03-E02","type":"multiple_choice","skill":"grammar","instruction":"Responde.","prompt":"Whose phone is it? It is ___ phone.","options":["my","I","me"],"correct_answer":"my","feedback_correct":"My va antes de phone.","feedback_incorrect":"Usa el posesivo, no el pronombre sujeto.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T07-L03-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"is / Whose / this / bag","correct_answer":"Whose bag is this?","feedback_correct":"Pregunta correcta.","feedback_incorrect":"Whose va antes del sustantivo.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L03-E04","type":"matching","skill":"vocabulary","instruction":"Relaciona.","prompt":"Whose?","options":["¿De quién?","¿Quién?","¿Qué?"],"correct_answer":"¿De quién?","feedback_correct":"Whose pregunta por pertenencia.","feedback_incorrect":"Who pregunta quién; whose pregunta de quién.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T07-L03-E05","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"Who book is this?","correct_answer":"Whose book is this?","feedback_correct":"La pregunta correcta es Whose book...?.","feedback_incorrect":"Cambia Who por Whose.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M1-T07-L03-E06","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"Whose jacket is this? It is her jacket.","options":["his","her","our"],"correct_answer":"her","feedback_correct":"Her indica pertenencia de ella.","feedback_incorrect":"Escucha la respuesta: her jacket.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L03-E07","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"Whose is this? It is my bag.","evaluation_criteria":["whose /huːz/ clear","question intonation"],"feedback_correct":"La pregunta suena clara.","feedback_incorrect":"Mantén la /z/ final de whose.","difficulty":2,"estimated_seconds":60},
    {"id":"A1-M1-T07-L03-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"Whose keys are these? They are our keys.","question":"Who owns the keys?","correct_answer":"We do.","feedback_correct":"Our indica nuestro.","feedback_incorrect":"Busca our keys.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L03-E09","type":"writing","skill":"writing","instruction":"Escribe tres preguntas y respuestas.","prompt":"Use Whose with a book, bag and phone.","response_type":"open","evaluation_criteria":["three whose questions","possessive answers"],"feedback_correct":"Preguntas y respuestas están completas.","feedback_incorrect":"Usa Whose + noun + is this?","difficulty":2,"estimated_seconds":80},
    {"id":"A1-M1-T07-L03-E10","type":"roleplay","skill":"interaction","instruction":"Encuentra al dueño de objetos.","prompt":"Ask the AI whose three objects are and answer about your own object.","role":"lost and found assistant","response_type":"open_speaking","success_criteria":["asks Whose","uses possessive answers"],"feedback_correct":"La pertenencia se comunica claramente.","feedback_incorrect":"Usa Whose para preguntar y my/his/her/their para responder.","difficulty":2,"estimated_seconds":110}
  ]
}
