{
  "id":"A1-M2-T05-L03",
  "level":"A1",
  "module_code":"A1-M2",
  "topic":"Negaciones",
  "title":"Negative answers",
  "objective":"Responder preguntas con respuestas negativas cortas y completas.",
  "activities":[
    {"id":"A1-M2-T05-L03-E01","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"Do you work on Sundays?","options":["No, I don't.","No, I doesn't.","No, not."],"correct_answer":"No, I don't.","feedback_correct":"I usa don't.","feedback_incorrect":"Usa No, I don't.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T05-L03-E02","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"Does she drive?","options":["No, she doesn't.","No, she don't.","No, she not."],"correct_answer":"No, she doesn't.","feedback_correct":"She usa doesn't.","feedback_incorrect":"Usa No, she doesn't.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T05-L03-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"don't / No / they","correct_answer":"No, they don't.","feedback_correct":"Respuesta corta correcta.","feedback_incorrect":"Ordena No + subject + don't.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M2-T05-L03-E04","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"No, he don't.","correct_answer":"No, he doesn't.","feedback_correct":"He usa doesn't.","feedback_incorrect":"Cambia don't por doesn't.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M2-T05-L03-E05","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"Does it rain here? No, it ___.","options":["doesn't","don't","isn't"],"correct_answer":"doesn't","feedback_correct":"It usa doesn't.","feedback_incorrect":"Usa doesn't con it.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T05-L03-E06","type":"listening","skill":"listening","instruction":"Escucha y responde.","prompt":"Do they eat meat? No, they don't.","question":"Do they eat meat?","correct_answer":"No.","feedback_correct":"La respuesta es negativa.","feedback_incorrect":"Escucha No, they don't.","difficulty":1,"estimated_seconds":45},
    {"id":"A1-M2-T05-L03-E07","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"No, I don't. No, she doesn't. No, they don't.","evaluation_criteria":["contractions clear","subject contrast","natural rhythm"],"feedback_correct":"Las respuestas se distinguen.","feedback_incorrect":"Practica cada sujeto con su auxiliar.","difficulty":2,"estimated_seconds":75},
    {"id":"A1-M2-T05-L03-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"Does Ana speak French? No, she doesn't. Does she speak English? Yes, she does.","question":"Does Ana speak French?","correct_answer":"No.","feedback_correct":"La primera respuesta es negativa.","feedback_incorrect":"Busca la respuesta a French.","difficulty":1,"estimated_seconds":45},
    {"id":"A1-M2-T05-L03-E09","type":"writing","skill":"writing","instruction":"Escribe respuestas.","prompt":"Write five questions and negative short answers.","response_type":"open","evaluation_criteria":["five questions","negative answers","auxiliary agreement"],"feedback_correct":"Las respuestas coinciden con el sujeto.","feedback_incorrect":"Revisa don’t con I/you/we/they y doesn’t con he/she/it.","difficulty":2,"estimated_seconds":100},
    {"id":"A1-M2-T05-L03-E10","type":"roleplay","skill":"interaction","instruction":"Responde una encuesta.","prompt":"Answer the AI's questions about things you do not do or like.","role":"survey interviewer","response_type":"open_speaking","success_criteria":["negative short answers","complete answers","clarification"],"feedback_correct":"Respondes con naturalidad.","feedback_incorrect":"La IA modela la respuesta y pide repetir.","difficulty":2,"estimated_seconds":120}
  ]
}
