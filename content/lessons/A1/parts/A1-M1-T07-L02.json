{
  "id":"A1-M1-T07-L02",
  "level":"A1",
  "module_code":"A1-M1",
  "topic":"Adjetivos posesivos",
  "title":"Our and their",
  "objective":"Expresar pertenencia de grupos con our y their.",
  "activities":[
    {"id":"A1-M1-T07-L02-E01","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"This is ___ house. We live here.","options":["our","their","your"],"correct_answer":"our","feedback_correct":"Our significa nuestro o nuestra.","feedback_incorrect":"We usa our.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T07-L02-E02","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"They are in ___ room.","options":["our","their","his"],"correct_answer":"their","feedback_correct":"Their indica pertenencia de they.","feedback_incorrect":"They usa their.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T07-L02-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"are / These / our / books","correct_answer":"These are our books.","feedback_correct":"Our va antes de books.","feedback_incorrect":"Usa These are our books.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L02-E04","type":"matching","skill":"vocabulary","instruction":"Relaciona.","prompt":"their car","options":["su carro de ellos","nuestro carro","tu carro"],"correct_answer":"su carro de ellos","feedback_correct":"Their se refiere a ellos o ellas.","feedback_incorrect":"Their corresponde a they.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M1-T07-L02-E05","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"We are students. This is their class.","correct_answer":"We are students. This is our class.","feedback_correct":"Si el sujeto es we, usamos our.","feedback_incorrect":"Cambia their por our.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L02-E06","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"Our teacher is kind.","options":["nuestro profesor","su profesor de ellos","mi profesor"],"correct_answer":"nuestro profesor","feedback_correct":"Our corresponde a we.","feedback_incorrect":"Escucha our.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L02-E07","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"our, their, our house, their house","evaluation_criteria":["clear /aʊr/","clear /ðer/","linking"],"feedback_correct":"Los posesivos se oyen antes del sustantivo.","feedback_incorrect":"Practica our y their lentamente.","difficulty":2,"estimated_seconds":65},
    {"id":"A1-M1-T07-L02-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"The children are in their room. We are in our room.","question":"Where are the children?","correct_answer":"In their room.","feedback_correct":"Their se refiere a the children.","feedback_incorrect":"Busca la primera frase.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L02-E09","type":"writing","skill":"writing","instruction":"Escribe frases.","prompt":"Write two sentences with our and two with their.","response_type":"open","evaluation_criteria":["four sentences","correct reference"],"feedback_correct":"La pertenencia de grupos está clara.","feedback_incorrect":"Our = we; their = they.","difficulty":2,"estimated_seconds":75},
    {"id":"A1-M1-T07-L02-E10","type":"roleplay","skill":"interaction","instruction":"Describe pertenencias de dos grupos.","prompt":"Tell the AI about your group's room and another group's room.","role":"tour guide","response_type":"open_speaking","success_criteria":["uses our","uses their","clear nouns"],"feedback_correct":"Comparaste dos pertenencias correctamente.","feedback_incorrect":"Usa our para tu grupo y their para el otro.","difficulty":2,"estimated_seconds":100}
  ]
}
