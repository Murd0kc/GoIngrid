{
  "id":"A1-M1-T07-L04",
  "level":"A1",
  "module_code":"A1-M1",
  "topic":"Adjetivos posesivos",
  "title":"Integrated ownership task",
  "objective":"Usar posesivos y Whose en una situación real.",
  "activities":[
    {"id":"A1-M1-T07-L04-E01","type":"listening","skill":"listening","instruction":"Escucha.","prompt":"Whose bag is this? It is her bag.","correct_answer":"her bag","feedback_correct":"Her indica pertenencia de ella.","feedback_incorrect":"Escucha la respuesta completa.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L04-E02","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"This is ___ classroom.","options":["our","us","we"],"correct_answer":"our","feedback_correct":"Our va antes de classroom.","feedback_incorrect":"Usa el posesivo de we.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T07-L04-E03","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"This is they book.","correct_answer":"This is their book.","feedback_correct":"Their indica pertenencia de they.","feedback_incorrect":"Cambia they por their.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M1-T07-L04-E04","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"is / Whose / this / phone","correct_answer":"Whose phone is this?","feedback_correct":"Pregunta correcta.","feedback_incorrect":"Whose va antes de phone.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L04-E05","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"Whose phone is this? It is my phone.","evaluation_criteria":["whose clear","my clear","question intonation"],"feedback_correct":"La pertenencia se entiende.","feedback_incorrect":"Repite Whose y my con claridad.","difficulty":2,"estimated_seconds":70},
    {"id":"A1-M1-T07-L04-E06","type":"reading","skill":"reading","instruction":"Lee.","prompt":"These are our seats. Those are their seats.","question":"Which seats belong to us?","correct_answer":"These are our seats.","feedback_correct":"Our significa de nosotros.","feedback_incorrect":"Busca our.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T07-L04-E07","type":"writing","skill":"writing","instruction":"Escribe un diálogo breve.","prompt":"Write a Whose question and an answer with a possessive adjective.","response_type":"open","evaluation_criteria":["question","answer","correct possessive"],"feedback_correct":"El diálogo expresa pertenencia.","feedback_incorrect":"Usa Whose y my/your/his/her/our/their.","difficulty":2,"estimated_seconds":75},
    {"id":"A1-M1-T07-L04-E08","type":"ai_roleplay","skill":"interaction","instruction":"Resuelve objetos perdidos.","prompt":"Ask whose three objects are and identify your own object.","role":"receptionist","response_type":"open_speaking","success_criteria":["three Whose questions","three possessive answers"],"feedback_correct":"La IA evalúa claridad y referencia.","feedback_incorrect":"Reformula con Whose + noun + is this?","difficulty":2,"estimated_seconds":150},
    {"id":"A1-M1-T07-L04-E09","type":"transfer","skill":"speaking","instruction":"Habla de tus pertenencias.","prompt":"Describe four objects near you and say whose they are.","response_type":"open_speaking","evaluation_criteria":["four possessives","clear ownership"],"feedback_correct":"Aplicaste el tema a objetos reales.","feedback_incorrect":"Usa my, his, her, our o their según el dueño.","difficulty":2,"estimated_seconds":100},
    {"id":"A1-M1-T07-L04-E10","type":"mastery_assessment","skill":"assessment","instruction":"Completa la evaluación.","prompt":"Ask and answer about five objects using Whose and possessive adjectives.","response_type":"open_speaking_and_writing","evaluation_criteria":["Whose accuracy","possessive accuracy","intelligibility","transfer"],"feedback_correct":"Tema dominado.","feedback_incorrect":"Repasa el posesivo asociado a cada pronombre.","difficulty":2,"estimated_seconds":180}
  ]
}
