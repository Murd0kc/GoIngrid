{
  "id":"A1-M1-T08-L02",
  "level":"A1",
  "module_code":"A1-M1",
  "topic":"Demostrativos",
  "title":"These and those",
  "objective":"Señalar varios objetos cercanos y lejanos.",
  "activities":[
    {"id":"A1-M1-T08-L02-E01","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"___ are my keys. They are here.","options":["These","Those","This"],"correct_answer":"These","feedback_correct":"These señala varios objetos cercanos.","feedback_incorrect":"Son varios y están aquí: these.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T08-L02-E02","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"___ are the cars over there.","options":["These","Those","That"],"correct_answer":"Those","feedback_correct":"Those señala varios objetos lejanos.","feedback_incorrect":"Over there indica distancia y plural.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T08-L02-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"are / These / my / shoes","correct_answer":"These are my shoes.","feedback_correct":"These usa are.","feedback_incorrect":"Empieza con These are.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T08-L02-E04","type":"matching","skill":"vocabulary","instruction":"Relaciona.","prompt":"those","options":["aquellos o aquellas","estos","eso"],"correct_answer":"aquellos o aquellas","feedback_correct":"Those es plural y lejano.","feedback_incorrect":"These es plural cercano; those lejano.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T08-L02-E05","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"These is my books.","correct_answer":"These are my books.","feedback_correct":"These es plural y usa are.","feedback_incorrect":"Cambia is por are.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M1-T08-L02-E06","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"Those are mountains.","options":["montañas lejanas","montaña cercana","un libro"],"correct_answer":"montañas lejanas","feedback_correct":"Those señala plural lejano.","feedback_incorrect":"Escucha those y mountains.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T08-L02-E07","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"These are here. Those are there.","evaluation_criteria":["/ðiːz/ clear","/ðoʊz/ clear","plural endings"],"feedback_correct":"La diferencia entre these y those es clara.","feedback_incorrect":"Practica /iː/ y /oʊ/.","difficulty":2,"estimated_seconds":65},
    {"id":"A1-M1-T08-L02-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"These are my books. Those are your books on the shelf.","question":"Which books are on the shelf?","correct_answer":"Your books.","feedback_correct":"Those señala los libros lejanos.","feedback_incorrect":"Busca la segunda frase.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T08-L02-E09","type":"writing","skill":"writing","instruction":"Escribe cuatro frases.","prompt":"Use these and those with familiar plural nouns.","response_type":"open","evaluation_criteria":["near/far contrast","are agreement","plural nouns"],"feedback_correct":"Usaste demostrativos plurales correctamente.","feedback_incorrect":"These/those usan are y sustantivo plural.","difficulty":2,"estimated_seconds":75},
    {"id":"A1-M1-T08-L02-E10","type":"roleplay","skill":"interaction","instruction":"Describe varios objetos.","prompt":"Point to two objects near you and two far away.","role":"classmate","response_type":"open_speaking","success_criteria":["these for near plural","those for far plural"],"feedback_correct":"La IA comprueba cantidad y distancia.","feedback_incorrect":"These = varios aquí; those = varios allí.","difficulty":2,"estimated_seconds":100}
  ]
}
