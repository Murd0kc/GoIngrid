{
  "id":"A1-M2-T01-L01",
  "level":"A1",
  "module_code":"A1-M2",
  "topic":"Orden correcto de las palabras",
  "title":"Basic English word order",
  "objective":"Formar frases afirmativas simples con sujeto, verbo y complemento.",
  "activities":[
    {"id":"A1-M2-T01-L01-E01","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"like / I / coffee","correct_answer":"I like coffee.","feedback_correct":"El sujeto va antes del verbo.","feedback_incorrect":"Usa subject + verb + object.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M2-T01-L01-E02","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"___ live in Miami.","options":["I","Live I","In Miami I"],"correct_answer":"I","feedback_correct":"I es el sujeto inicial.","feedback_incorrect":"Empieza con el sujeto.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T01-L01-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"English / study / We","correct_answer":"We study English.","feedback_correct":"Frase correcta.","feedback_incorrect":"Empieza con We.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M2-T01-L01-E04","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"Coffee I like.","correct_answer":"I like coffee.","feedback_correct":"El orden neutral es sujeto + verbo + objeto.","feedback_incorrect":"Mueve I al inicio.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M2-T01-L01-E05","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"She ___ music.","options":["likes","music likes","like she"],"correct_answer":"likes","feedback_correct":"El verbo va después del sujeto.","feedback_incorrect":"La frase empieza She y luego verbo.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T01-L01-E06","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"They play soccer.","options":["Ellos juegan fútbol","Ellos estudian inglés","Ellos comen arroz"],"correct_answer":"Ellos juegan fútbol","feedback_correct":"Entendiste sujeto, verbo y objeto.","feedback_incorrect":"Play soccer significa jugar fútbol.","difficulty":1,"estimated_seconds":45},
    {"id":"A1-M2-T01-L01-E07","type":"pronunciation","skill":"pronunciation","instruction":"Lee.","prompt":"I like coffee. We study English. She plays music.","evaluation_criteria":["subject clear","verb clear","natural rhythm"],"feedback_correct":"El orden se entiende al hablar.","feedback_incorrect":"Haz una pausa breve entre grupos de palabras.","difficulty":1,"estimated_seconds":70},
    {"id":"A1-M2-T01-L01-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"Carlos reads books. He studies at home.","question":"What does Carlos read?","correct_answer":"Books.","feedback_correct":"Books es el objeto de reads.","feedback_incorrect":"Busca el primer verbo y lo que sigue.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M2-T01-L01-E09","type":"writing","skill":"writing","instruction":"Escribe cinco frases.","prompt":"Write five subject + verb + object sentences.","response_type":"open","evaluation_criteria":["five sentences","correct word order","clear meaning"],"feedback_correct":"El orden de las frases es claro.","feedback_incorrect":"Usa sujeto, verbo y complemento.","difficulty":1,"estimated_seconds":90},
    {"id":"A1-M2-T01-L01-E10","type":"roleplay","skill":"interaction","instruction":"Habla de actividades.","prompt":"Tell the AI five things you do or like using basic word order.","role":"new classmate","response_type":"open_speaking","success_criteria":["five statements","subject before verb","clear objects"],"feedback_correct":"La conversación es comprensible.","feedback_incorrect":"Reformula cada frase con subject + verb + object.","difficulty":2,"estimated_seconds":120}
  ]
}
