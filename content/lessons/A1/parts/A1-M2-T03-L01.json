  "module_code":"A1-M2",
  "topic":"Auxiliares do y does",
  "title":"Do in questions",
  "objective":"Usar do para formar preguntas con I, you, we y they.",
  "activities":[
    {"id":"A1-M2-T03-L01-E01","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"___ you like tea?","options":["Do","Does","Are"],"correct_answer":"Do","feedback_correct":"You usa do.","feedback_incorrect":"Con you usamos Do.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T03-L01-E02","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"___ they work here?","options":["Do","Does","Is"],"correct_answer":"Do","feedback_correct":"They usa do.","feedback_incorrect":"Con they usamos Do.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T03-L01-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"you / Do / live / here?","correct_answer":"Do you live here?","feedback_correct":"Pregunta correcta.","feedback_incorrect":"Do + subject + base verb.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M2-T03-L01-E04","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"Do she study English?","correct_answer":"Does she study English?","feedback_correct":"She usa does.","feedback_incorrect":"Cambia Do por Does.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M2-T03-L01-E05","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"Do we ___ dinner here?","options":["eat","eats","eating"],"correct_answer":"eat","feedback_correct":"Después de do usamos verbo base.","feedback_incorrect":"No añadas -s después de do.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T03-L01-E06","type":"listening","skill":"listening","instruction":"Escucha y responde.","prompt":"Do you speak English? Yes, I do.","question":"Does the person speak English?","correct_answer":"Yes.","feedback_correct":"Yes, I do confirma la respuesta.","feedback_incorrect":"Escucha la respuesta corta.","difficulty":1,"estimated_seconds":45},
    {"id":"A1-M2-T03-L01-E07","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"Do you work? Do they study?","evaluation_criteria":["do clear","question intonation","base verbs"],"feedback_correct":"Las preguntas se entienden.","feedback_incorrect":"Mantén do y no añadas una terminación al verbo.","difficulty":2,"estimated_seconds":65},
    {"id":"A1-M2-T03-L01-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"Do you cook? Yes, I do. Do you cook every day? No, I don't.","question":"Does the person cook every day?","correct_answer":"No.","feedback_correct":"No, I don't lo indica.","feedback_incorrect":"Busca la segunda respuesta.","difficulty":2,"estimated_seconds":45},
    {"id":"A1-M2-T03-L01-E09","type":"writing","skill":"writing","instruction":"Escribe preguntas.","prompt":"Write five Do questions about daily life.","response_type":"open","evaluation_criteria":["five questions","Do with correct subjects","base verbs"],"feedback_correct":"Las preguntas están bien formadas.","feedback_incorrect":"Usa Do + I/you/we/they + verb.","difficulty":2,"estimated_seconds":90},
    {"id":"A1-M2-T03-L01-E10","type":"roleplay","skill":"interaction","instruction":"Entrevista a la IA.","prompt":"Ask five Do questions and answer five questions about habits.","role":"new friend","response_type":"open_speaking","success_criteria":["five Do questions","short answers"],"feedback_correct":"La entrevista es clara.","feedback_incorrect":"Reformula con Do + subject + base verb.","difficulty":2,"estimated_seconds":120}
  ]
}
