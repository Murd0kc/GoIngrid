  "topic":"Demostrativos",
  "title":"This and that",
  "objective":"Señalar objetos cercanos y lejanos con this y that.",
  "activities":[
    {"id":"A1-M1-T08-L01-E01","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"___ is my pen. It is here.","options":["This","That","Those"],"correct_answer":"This","feedback_correct":"This señala una cosa cercana.","feedback_incorrect":"El objeto está aquí: this.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T08-L01-E02","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"___ is the bus over there.","options":["This","That","These"],"correct_answer":"That","feedback_correct":"That señala una cosa lejana.","feedback_incorrect":"Over there indica distancia.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T08-L01-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"is / This / my / book","correct_answer":"This is my book.","feedback_correct":"This va antes de is.","feedback_incorrect":"Empieza con This.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T08-L01-E04","type":"matching","skill":"vocabulary","instruction":"Relaciona.","prompt":"that","options":["eso o esa cosa","esto","estos"],"correct_answer":"eso o esa cosa","feedback_correct":"That señala una cosa singular lejana.","feedback_incorrect":"This es esto; that es eso.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T08-L01-E05","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"That are my bag.","correct_answer":"That is my bag.","feedback_correct":"That es singular y usa is.","feedback_incorrect":"Cambia are por is.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M1-T08-L01-E06","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"This is my phone.","options":["objeto cercano","objeto lejano","varios objetos"],"correct_answer":"objeto cercano","feedback_correct":"This indica cercanía.","feedback_incorrect":"Escucha this.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T08-L01-E07","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"This is here. That is there.","evaluation_criteria":["/ð/ clear","this and that distinct","natural stress"],"feedback_correct":"La distancia se entiende por la palabra.","feedback_incorrect":"Practica /ðɪs/ y /ðæt/.","difficulty":2,"estimated_seconds":60},
    {"id":"A1-M1-T08-L01-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"This is my cup. That is your cup on the table.","question":"Which cup is on the table?","correct_answer":"Your cup.","feedback_correct":"That señala la taza lejana.","feedback_incorrect":"Busca la segunda frase.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T08-L01-E09","type":"writing","skill":"writing","instruction":"Escribe frases.","prompt":"Write two sentences with this and two with that.","response_type":"open","evaluation_criteria":["near/far contrast","is agreement"],"feedback_correct":"Distinguiste cercanía y distancia.","feedback_incorrect":"This/that son singulares y usan is.","difficulty":1,"estimated_seconds":70},
    {"id":"A1-M1-T08-L01-E10","type":"roleplay","skill":"interaction","instruction":"Señala objetos.","prompt":"Point to one object near you and one far away and describe them.","role":"classmate","response_type":"open_speaking","success_criteria":["this for near","that for far"],"feedback_correct":"La IA comprueba el contexto espacial.","feedback_incorrect":"This = aquí; that = allí.","difficulty":2,"estimated_seconds":90}
  ]
