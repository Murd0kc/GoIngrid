{
  "id": "A1-M1-T06-L01",
  "level": "A1",
  "module_code": "A1-M1",
  "topic": "Adjetivos",
  "title": "Describing people and things",
  "objective": "Usar adjetivos básicos para describir personas y objetos.",
  "activities": [
    {"id":"A1-M1-T06-L01-E01","type":"multiple_choice","skill":"grammar","instruction":"Completa.","prompt":"She is ___ .","options":["happy","happily","happiness"],"correct_answer":"happy","feedback_correct":"Happy es un adjetivo.","feedback_incorrect":"Después de is necesitamos un adjetivo.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T06-L01-E02","type":"matching","skill":"vocabulary","instruction":"Relaciona.","prompt":"big","options":["grande","rápido","nuevo"],"correct_answer":"grande","feedback_correct":"Big significa grande.","feedback_incorrect":"Big describe tamaño.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T06-L01-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"a / car / red","correct_answer":"a red car","feedback_correct":"El adjetivo va antes del sustantivo.","feedback_incorrect":"En inglés: adjective + noun.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T06-L01-E04","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"a ___ house","options":["beautiful","beautifully","beauty"],"correct_answer":"beautiful","feedback_correct":"Beautiful describe house.","feedback_incorrect":"Necesitamos un adjetivo.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M1-T06-L01-E05","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"a car blue","correct_answer":"a blue car","feedback_correct":"El adjetivo precede al sustantivo.","feedback_incorrect":"Mueve blue antes de car.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M1-T06-L01-E06","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"a small bag","options":["a small bag","a big bag","a new book"],"correct_answer":"a small bag","feedback_correct":"Small significa pequeño.","feedback_incorrect":"Escucha el adjetivo antes de bag.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M1-T06-L01-E07","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"big, small, happy","evaluation_criteria":["clear final consonants","clear vowels"],"feedback_correct":"Los adjetivos se entienden claramente.","feedback_incorrect":"Repite lentamente y conserva las consonantes finales.","difficulty":1,"estimated_seconds":60},
    {"id":"A1-M1-T06-L01-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"The old house is white.","question":"What color is the house?","correct_answer":"White","feedback_correct":"White es el color.","feedback_incorrect":"Busca el adjetivo después de is.","difficulty":1,"estimated_seconds":35},
    {"id":"A1-M1-T06-L01-E09","type":"writing","skill":"writing","instruction":"Describe tres objetos.","prompt":"Write three adjective + noun phrases.","response_type":"open","evaluation_criteria":["three adjectives","adjective before noun"],"feedback_correct":"Tus frases tienen el orden correcto.","feedback_incorrect":"Usa: a new phone, a big table.","difficulty":1,"estimated_seconds":60},
    {"id":"A1-M1-T06-L01-E10","type":"roleplay","skill":"interaction","instruction":"Describe objetos a la IA.","prompt":"Describe three objects in a room using simple adjectives.","role":"friend","response_type":"open_speaking","success_criteria":["three adjective+noun phrases"],"feedback_correct":"La descripción es comprensible.","feedback_incorrect":"Pon el adjetivo antes del sustantivo.","difficulty":1,"estimated_seconds":90}
  ]
}
