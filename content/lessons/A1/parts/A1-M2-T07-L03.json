{
  "id":"A1-M2-T07-L03",
  "level":"A1",
  "module_code":"A1-M2",
  "topic":"Palabras interrogativas",
  "title":"Answering wh-questions",
  "objective":"Responder con información completa y adecuada.",
  "activities":[
    {"id":"A1-M2-T07-L03-E01","type":"multiple_choice","skill":"grammar","instruction":"Responde.","prompt":"Where do you live?","options":["In Lima.","At seven.","Because I work."],"correct_answer":"In Lima.","feedback_correct":"Where pide un lugar.","feedback_incorrect":"Elige una respuesta de lugar.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T07-L03-E02","type":"multiple_choice","skill":"grammar","instruction":"Responde.","prompt":"When do you study?","options":["At night.","In Mexico.","Because I like it."],"correct_answer":"At night.","feedback_correct":"When pide un tiempo.","feedback_incorrect":"Elige una hora o momento.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T07-L03-E03","type":"multiple_choice","skill":"grammar","instruction":"Responde.","prompt":"Why do you learn English?","options":["Because I need it.","At home.","By bus."],"correct_answer":"Because I need it.","feedback_correct":"Why pide una razón.","feedback_incorrect":"Usa Because para explicar el motivo.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T07-L03-E04","type":"multiple_choice","skill":"grammar","instruction":"Responde.","prompt":"How do you travel?","options":["By bus.","On Monday.","My sister."],"correct_answer":"By bus.","feedback_correct":"How pide una manera.","feedback_incorrect":"Elige un medio o forma.","difficulty":1,"estimated_seconds":30},
    {"id":"A1-M2-T07-L03-E05","type":"error_correction","skill":"grammar","instruction":"Corrige la respuesta.","prompt":"Where do you work? At eight.","correct_answer":"Where do you work? At a hospital.","feedback_correct":"Where necesita un lugar.","feedback_incorrect":"Cambia la hora por un lugar.","difficulty":1,"estimated_seconds":40},
    {"id":"A1-M2-T07-L03-E06","type":"listening","skill":"listening","instruction":"Escucha y relaciona.","prompt":"Who is he? My brother. When does he work? In the morning.","question":"Who is he?","correct_answer":"My brother.","feedback_correct":"Who pide una persona.","feedback_incorrect":"Escucha la primera respuesta.","difficulty":1,"estimated_seconds":50},
    {"id":"A1-M2-T07-L03-E07","type":"pronunciation","skill":"pronunciation","instruction":"Graba preguntas y respuestas.","prompt":"Where do you live? I live in Lima. Why do you study? Because I enjoy it.","evaluation_criteria":["question-answer rhythm","clear wh-word","natural response"],"feedback_correct":"Las respuestas corresponden a cada pregunta.","feedback_incorrect":"Practica pregunta y respuesta como una unidad.","difficulty":2,"estimated_seconds":80},
    {"id":"A1-M2-T07-L03-E08","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"What does Sara eat? She eats fruit. How does she get to work? By train.","question":"How does Sara get to work?","correct_answer":"By train.","feedback_correct":"Identificaste la respuesta de manera.","feedback_incorrect":"Busca la pregunta How.","difficulty":2,"estimated_seconds":45},
    {"id":"A1-M2-T07-L03-E09","type":"writing","skill":"writing","instruction":"Responde preguntas.","prompt":"Answer six wh-questions about yourself in complete sentences.","response_type":"open","evaluation_criteria":["six answers","information matches question","complete sentences"],"feedback_correct":"Cada respuesta corresponde a la pregunta.","feedback_incorrect":"Comprueba si pide persona, lugar, tiempo, razón o manera.","difficulty":2,"estimated_seconds":100},
    {"id":"A1-M2-T07-L03-E10","type":"roleplay","skill":"interaction","instruction":"Responde a una entrevista.","prompt":"Answer the AI's six questions and ask one clarification question.","role":"native-speaking interviewer","response_type":"open_speaking","success_criteria":["appropriate answers","clarification","complete sentences"],"feedback_correct":"La conversación mantiene el sentido.","feedback_incorrect":"La IA te indica qué tipo de información falta.","difficulty":2,"estimated_seconds":130}
  ]
}
