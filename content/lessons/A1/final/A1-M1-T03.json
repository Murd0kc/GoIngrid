{
  "id": "A1-M1-T03",
  "level": "A1",
  "module_code": "A1-M1",
  "topic": "Verbo to be",
  "title": "Am, is and are",
  "estimated_seconds": 3600,
  "communication_goal": "Usar am, is y are para describir identidad, estado y ubicación.",
  "cefr_objectives": [
    "Can give basic personal information.",
    "Can describe people and places with short sentences."
  ],
  "explanation_es": "El verbo to be cambia según el sujeto: I am, he/she/it is, you/we/they are. En inglés el sujeto debe aparecer explícitamente.",
  "key_language": [
    "I am tired.",
    "You are ready.",
    "She is a doctor.",
    "We are at home.",
    "They are happy."
  ],
  "spanish_speaker_notes": [
    "No omitas el sujeto.",
    "No uses is con I.",
    "No uses am con he, she o they.",
    "Are se usa con you, we y they."
  ],
  "pronunciation_targets": [
    {
      "text": "I am",
      "ipa": "/aɪ æm/",
      "error": "omitir am"
    },
    {
      "text": "he is",
      "ipa": "/hi ɪz/",
      "error": "pronunciar is como una sola vocal"
    },
    {
      "text": "we are",
      "ipa": "/wi ɑr/",
      "error": "confundir we con be"
    }
  ],
