{
  "id":"A1-M1-T05",
  "level":"A1",
  "module_code":"A1-M1",
  "topic":"Sustantivos y plurales",
  "title":"Nouns and plurals",
  "estimated_seconds":3600,
  "communication_goal":"Nombrar objetos cotidianos y hablar de uno o varios elementos.",
  "cefr_objectives":["Can name familiar objects.","Can form regular plurals.","Can recognize common irregular plurals."],
  "explanation_es":"Los sustantivos nombran personas, animales, objetos o ideas. La mayoría de los plurales se forman con -s; después de ciertos sonidos usamos -es y algunos plurales son irregulares.",
  "key_language":["one book","two books","one box","two boxes","a child","two children"],
  "spanish_speaker_notes":["No añadas una vocal final al plural.","La -s final puede sonar /s/, /z/ o /ɪz/.","Children ya es plural: no digas childrens."],
  "vocabulary":[{"term":"book","meaning_es":"libro"},{"term":"box","meaning_es":"caja"},{"term":"class","meaning_es":"clase"},{"term":"child","meaning_es":"niño o niña"},{"term":"person","meaning_es":"persona"},{"term":"woman","meaning_es":"mujer"},{"term":"man","meaning_es":"hombre"}],
  "pronunciation_targets":[{"text":"books","ipa":"/bʊks/","error":"añadir una vocal final"},{"text":"boxes","ipa":"/ˈbɒksɪz/","error":"omitir la sílaba final"},{"text":"children","ipa":"/ˈtʃɪldrən/","error":"formar childrens"}],
  "lessons":[
    {"id":"A1-M1-T05-L01","title":"Regular plurals with -s","objective":"Formar plurales regulares básicos.","estimated_seconds":900,"activities":[
      {"id":"A1-M1-T05-L01-E01","type":"multiple_choice","skill":"grammar","instruction":"Elige el plural.","prompt":"one book, two ___","options":["book","books","bookes"],"correct_answer":"books","feedback_correct":"Añadimos -s.","feedback_incorrect":"La mayoría de sustantivos forma plural con -s.","difficulty":1,"estimated_seconds":30},
      {"id":"A1-M1-T05-L01-E02","type":"multiple_choice","skill":"vocabulary","instruction":"Elige el significado.","prompt":"chairs","options":["una silla","sillas","mesas"],"correct_answer":"sillas","feedback_correct":"Chairs es plural de chair.","feedback_incorrect":"La -s indica más de una.","difficulty":1,"estimated_seconds":30},
      {"id":"A1-M1-T05-L01-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"two / books / have / I","correct_answer":"I have two books.","feedback_correct":"Two books es plural.","feedback_incorrect":"Empieza con I have.","difficulty":1,"estimated_seconds":40},
      {"id":"A1-M1-T05-L01-E04","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"I have two book.","correct_answer":"I have two books.","feedback_correct":"Two necesita plural.","feedback_incorrect":"Añade -s a book.","difficulty":1,"estimated_seconds":35},
      {"id":"A1-M1-T05-L01-E05","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"three pens","options":["one pen","three pens","three books"],"correct_answer":"three pens","feedback_correct":"Escuchaste el número y el plural.","feedback_incorrect":"Identifica three y pens.","difficulty":1,"estimated_seconds":40},
      {"id":"A1-M1-T05-L01-E06","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"book, books; pen, pens","evaluation_criteria":["no extra vowel","final consonant audible"],"feedback_correct":"La pluralidad se entiende por la terminación.","feedback_incorrect":"Termina en consonante sin añadir e.","difficulty":1,"estimated_seconds":60},
      {"id":"A1-M1-T05-L01-E07","type":"reading","skill":"reading","instruction":"Lee.","prompt":"There are four chairs and two tables.","question":"How many chairs?","correct_answer":"Four","feedback_correct":"Hay cuatro sillas.","feedback_incorrect":"Busca el número antes de chairs.","difficulty":1,"estimated_seconds":35},
      {"id":"A1-M1-T05-L01-E08","type":"writing","skill":"writing","instruction":"Escribe frases.","prompt":"Write three sentences with one and two familiar objects.","response_type":"open","evaluation_criteria":["singular and plural contrast"],"feedback_correct":"Distinguiste singular y plural.","feedback_incorrect":"Usa one + singular y two + plural.","difficulty":1,"estimated_seconds":70},
      {"id":"A1-M1-T05-L01-E09","type":"roleplay","skill":"interaction","instruction":"Cuenta objetos en una tienda.","prompt":"Tell the AI what you need: one item and two other items.","role":"shop assistant","response_type":"open_speaking","success_criteria":["uses singular","uses plural"],"feedback_correct":"La cantidad y el plural coinciden.","feedback_incorrect":"Revisa el sustantivo después del número.","difficulty":1,"estimated_seconds":90},
      {"id":"A1-M1-T05-L01-E10","type":"review","skill":"review","instruction":"Completa.","prompt":"one class, two ___","options":["class","classes","classs"],"correct_answer":"classes","feedback_correct":"Class usa -es.","feedback_incorrect":"Después de s usamos -es.","difficulty":1,"estimated_seconds":35}
    ]},
    {"id":"A1-M1-T05-L02","title":"Plural spelling rules","objective":"Formar plurales con -es y cambios ortográficos frecuentes.","estimated_seconds":900,"activities":[
      {"id":"A1-M1-T05-L02-E01","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"one box, two ___","options":["boxs","boxes","boxies"],"correct_answer":"boxes","feedback_correct":"Box termina en x y usa -es.","feedback_incorrect":"Después de x usamos -es.","difficulty":1,"estimated_seconds":30},
      {"id":"A1-M1-T05-L02-E02","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"one bus, two ___","options":["buses","buss","buseses"],"correct_answer":"buses","feedback_correct":"Bus forma buses.","feedback_incorrect":"Después de s usamos -es.","difficulty":1,"estimated_seconds":30},
      {"id":"A1-M1-T05-L02-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"three / watches / have / We","correct_answer":"We have three watches.","feedback_correct":"Watches es plural de watch.","feedback_incorrect":"Empieza con We have.","difficulty":1,"estimated_seconds":40},
      {"id":"A1-M1-T05-L02-E04","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"two dish","correct_answer":"two dishes","feedback_correct":"Dish usa -es.","feedback_incorrect":"Añade -es después de sh.","difficulty":1,"estimated_seconds":35},
      {"id":"A1-M1-T05-L02-E05","type":"listening","skill":"listening","instruction":"Escucha.","prompt":"two watches","options":["two watches","two watches?","one watch"],"correct_answer":"two watches","feedback_correct":"Escuchaste el plural completo.","feedback_incorrect":"La palabra tiene una sílaba final /ɪz/.","difficulty":2,"estimated_seconds":45},
      {"id":"A1-M1-T05-L02-E06","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"cats, dogs, boxes","evaluation_criteria":["/s/","/z/","/ɪz/ distinction"],"feedback_correct":"Las terminaciones suenan diferentes según el sonido final.","feedback_incorrect":"Compara cats, dogs y boxes.","difficulty":2,"estimated_seconds":75},
      {"id":"A1-M1-T05-L02-E07","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"The shop has six boxes and three watches.","question":"What has six?","correct_answer":"Boxes","feedback_correct":"Boxes aparece con six.","feedback_incorrect":"Busca el sustantivo después de six.","difficulty":1,"estimated_seconds":40},
      {"id":"A1-M1-T05-L02-E08","type":"writing","skill":"writing","instruction":"Escribe cinco plurales.","prompt":"Write five nouns ending in s, x, sh or ch and their plurals.","response_type":"open","evaluation_criteria":["correct -es spelling"],"feedback_correct":"Aplicaste las reglas ortográficas.","feedback_incorrect":"Revisa si el final necesita -es.","difficulty":2,"estimated_seconds":80},
      {"id":"A1-M1-T05-L02-E09","type":"roleplay","skill":"interaction","instruction":"Cuenta productos.","prompt":"Tell the AI how many boxes, dishes and watches you need.","role":"store clerk","response_type":"open_speaking","success_criteria":["three correct -es plurals"],"feedback_correct":"La cantidad y las terminaciones son claras.","feedback_incorrect":"Practica cada plural lentamente.","difficulty":2,"estimated_seconds":100},
      {"id":"A1-M1-T05-L02-E10","type":"review","skill":"review","instruction":"Elige la regla.","prompt":"A noun ending in x usually forms its plural with...","options":["-s","-es","-ed"],"correct_answer":"-es","feedback_correct":"Box becomes boxes.","feedback_incorrect":"x necesita -es.","difficulty":1,"estimated_seconds":35}
    ]},
    {"id":"A1-M1-T05-L03","title":"Irregular plurals","objective":"Reconocer plurales frecuentes que no usan solo -s.","estimated_seconds":900,"activities":[
      {"id":"A1-M1-T05-L03-E01","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"one child, two ___","options":["childs","children","childes"],"correct_answer":"children","feedback_correct":"Children es el plural irregular.","feedback_incorrect":"No digas childs.","difficulty":1,"estimated_seconds":30},
      {"id":"A1-M1-T05-L03-E02","type":"multiple_choice","skill":"vocabulary","instruction":"Elige.","prompt":"one person, two ___","options":["persons","people","peoples"],"correct_answer":"people","feedback_correct":"People es el plural común de person.","feedback_incorrect":"El plural común es people.","difficulty":1,"estimated_seconds":30},
      {"id":"A1-M1-T05-L03-E03","type":"matching","skill":"vocabulary","instruction":"Relaciona.","prompt":"woman","options":["women","womanes","womans"],"correct_answer":"women","feedback_correct":"Woman cambia a women.","feedback_incorrect":"El plural irregular es women.","difficulty":1,"estimated_seconds":35},
      {"id":"A1-M1-T05-L03-E04","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"There are two childs.","correct_answer":"There are two children.","feedback_correct":"Child tiene plural children.","feedback_incorrect":"Sustituye childs por children.","difficulty":1,"estimated_seconds":40},
      {"id":"A1-M1-T05-L03-E05","type":"listening","skill":"listening","instruction":"Escucha y elige.","prompt":"three people","options":["three people","three persons only","one people"],"correct_answer":"three people","feedback_correct":"People es plural de person.","feedback_incorrect":"Escucha people.","difficulty":1,"estimated_seconds":40},
      {"id":"A1-M1-T05-L03-E06","type":"pronunciation","skill":"pronunciation","instruction":"Graba.","prompt":"child, children; woman, women","evaluation_criteria":["clear vowel change","children final syllables"],"feedback_correct":"Los cambios de vocal son importantes.","feedback_incorrect":"Repite child-children y woman-women.","difficulty":2,"estimated_seconds":75},
      {"id":"A1-M1-T05-L03-E07","type":"reading","skill":"reading","instruction":"Lee.","prompt":"Two children and three women are in the room.","question":"How many children?","correct_answer":"Two","feedback_correct":"Hay dos niños o niñas.","feedback_incorrect":"Busca children.","difficulty":1,"estimated_seconds":35},
      {"id":"A1-M1-T05-L03-E08","type":"writing","skill":"writing","instruction":"Escribe frases con plurales irregulares.","prompt":"Use children, people, men and women in four sentences.","response_type":"open","evaluation_criteria":["four correct irregular plurals"],"feedback_correct":"Usaste los plurales sin añadir -s.","feedback_incorrect":"Revisa cada forma irregular.","difficulty":2,"estimated_seconds":80},
      {"id":"A1-M1-T05-L03-E09","type":"roleplay","skill":"interaction","instruction":"Describe un grupo.","prompt":"Tell the AI how many people, children and women or men are present.","role":"event organizer","response_type":"open_speaking","success_criteria":["uses irregular plurals"],"feedback_correct":"La información del grupo es clara.","feedback_incorrect":"Usa people, children, men o women.","difficulty":2,"estimated_seconds":100},
      {"id":"A1-M1-T05-L03-E10","type":"review","skill":"review","instruction":"Completa.","prompt":"one man, two ___","options":["mans","men","manes"],"correct_answer":"men","feedback_correct":"Man cambia a men.","feedback_incorrect":"El plural es men.","difficulty":1,"estimated_seconds":35}
    ]},
    {"id":"A1-M1-T05-L04","title":"Nouns in real situations","objective":"Usar singulares y plurales en descripciones nuevas.","estimated_seconds":900,"activities":[
      {"id":"A1-M1-T05-L04-E01","type":"multiple_choice","skill":"grammar","instruction":"Elige.","prompt":"There are three ___ on the desk.","options":["book","books","bookes"],"correct_answer":"books","feedback_correct":"Three necesita plural.","feedback_incorrect":"Usa books después de three.","difficulty":1,"estimated_seconds":30},
      {"id":"A1-M1-T05-L04-E02","type":"listening","skill":"listening","instruction":"Escucha y elige la escena.","prompt":"There are two boxes and one child.","options":["dos cajas y un niño","una caja y dos niños","tres libros"],"correct_answer":"dos cajas y un niño","feedback_correct":"Identificaste plural y singular.","feedback_incorrect":"Escucha two boxes y one child.","difficulty":2,"estimated_seconds":50},
      {"id":"A1-M1-T05-L04-E03","type":"ordering","skill":"grammar","instruction":"Ordena.","prompt":"are / five / There / people","correct_answer":"There are five people.","feedback_correct":"People es el plural correcto.","feedback_incorrect":"Usa There are five people.","difficulty":2,"estimated_seconds":45},
      {"id":"A1-M1-T05-L04-E04","type":"error_correction","skill":"grammar","instruction":"Corrige.","prompt":"There is two chairs.","correct_answer":"There are two chairs.","feedback_correct":"Two chairs necesita are.","feedback_incorrect":"Usa are con plural.","difficulty":2,"estimated_seconds":40},
      {"id":"A1-M1-T05-L04-E05","type":"pronunciation","skill":"pronunciation","instruction":"Lee la descripción.","prompt":"There are two boxes, three books and four children.","evaluation_criteria":["plural endings","numbers clear","no added vowels"],"feedback_correct":"La descripción se entiende con claridad.","feedback_incorrect":"Practica cada plural con su número.","difficulty":2,"estimated_seconds":90},
      {"id":"A1-M1-T05-L04-E06","type":"reading","skill":"reading","instruction":"Lee y responde.","prompt":"The classroom has ten students, two teachers and three tables.","question":"How many teachers?","correct_answer":"Two","feedback_correct":"Hay dos profesores.","feedback_incorrect":"Busca teachers.","difficulty":1,"estimated_seconds":40},
      {"id":"A1-M1-T05-L04-E07","type":"writing","skill":"writing","instruction":"Describe una habitación.","prompt":"Write six sentences using singular, regular plural and irregular plural nouns.","response_type":"open","evaluation_criteria":["six sentences","three plural patterns","clear meaning"],"feedback_correct":"La descripción combina varios tipos de plural.","feedback_incorrect":"Incluye al menos un plural con -s, uno con -es y uno irregular.","difficulty":2,"estimated_seconds":120},
      {"id":"A1-M1-T05-L04-E08","type":"ai_roleplay","skill":"interaction","instruction":"Haz un inventario.","prompt":"Describe the objects and people in a classroom to the AI. Answer how many questions.","role":"class assistant","response_type":"open_speaking","success_criteria":["singular/plural agreement","regular plural","irregular plural"],"feedback_correct":"La IA evalúa cantidad, forma y claridad.","feedback_incorrect":"La IA pide reformular una cantidad concreta.","difficulty":2,"estimated_seconds":150},
      {"id":"A1-M1-T05-L04-E09","type":"transfer","skill":"speaking","instruction":"Haz un inventario de tu entorno.","prompt":"Name one object, three regular plurals and one irregular plural around you.","response_type":"open_speaking","evaluation_criteria":["five nouns","plural accuracy","intelligibility"],"feedback_correct":"Aplicaste los plurales a objetos nuevos.","feedback_incorrect":"Comprueba cada forma en un diccionario interno o pide ayuda a la IA.","difficulty":2,"estimated_seconds":100},
      {"id":"A1-M1-T05-L04-E10","type":"mastery_assessment","skill":"assessment","instruction":"Completa la evaluación.","prompt":"Describe a room using singular, regular plural, -es plural and an irregular plural.","response_type":"open_speaking_and_writing","evaluation_criteria":["four noun patterns","there is/are agreement","intelligibility","transfer"],"feedback_correct":"Tema dominado: distingues cantidad y formas plurales.","feedback_incorrect":"Repasa la regla correspondiente al error detectado.","difficulty":2,"estimated_seconds":180}
    ]}
  ],
  "review_schedule":[1,3,7,14,30],
  "mastery_criteria":{"minimum_score":0.8,"transfer_required":true,"pronunciation_is_intelligibility_first":true}
}
